```gitignore
# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Build outputs
dist/
build/
target/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# Gradle
.gradle/

# OS generated files
.DS_Store
Thumbs.db
```